    <text x="163" y="62" font-size="10" fill="var(--color-text-muted)" font-family="var(--font-mono)">(FPR=0.2, TPR=0.8)</text>
    <!-- diagonal label -->
    <text x="330" y="55" font-size="10" fill="var(--color-text-muted)" font-family="var(--font-sans)" transform="rotate(-40 330 55)">random</text>
  </svg>
