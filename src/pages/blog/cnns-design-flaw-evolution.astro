      </div>
    </div>
  </div>
  <div class="stream-diagram">
    <h4 class="diagram-title">Ventral Stream — "What"</h4>
    <div class="flow">
      <div class="flow-step"><span class="flow-node">Retina</span></div>
      <div class="flow-step"><span class="flow-node">LGN</span></div>
      <div class="flow-step"><span class="flow-node">V1</span><span class="flow-label">fine detail, colour, high freq</span></div>
      <div class="flow-step"><span class="flow-node">V2</span><span class="flow-label">contours, figure-ground, illusionary edges</span></div>
