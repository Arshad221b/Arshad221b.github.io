          </div>
        </div>
      </div>
      <div class="v4f-desc">factors out illumination — computes colour relative to surroundings</div>
    </div>
    <div class="v4f-card">
      <div class="v4f-number">2</div>
      <div class="v4f-title">Shape & Curves</div>
      <div class="v4f-visual">
        <div class="v4f-shapes">
          <svg class="v4f-shape-svg" viewBox="0 0 60 40">
