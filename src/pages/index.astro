---
import Layout from '../layouts/Layout.astro';

const title = "Arshad Kazi";
---

<Layout title={title} activeNav="/">
  <div class="page-header">
    <h1>Arshad Kazi</h1>
    <p class="page-subtitle">Computer vision researcher. Interested in geometry, 3D understanding, and building things that see.</p>
  </div>

  <div class="about-intro">
    <p>
      I work at the intersection of computer vision and geometry. My research focuses on
      how machines can understand the 3D structure of the world from images &mdash; from
      depth estimation and camera calibration to scene reconstruction and beyond.
    </p>
    <p>
      This site is a home for my technical writing and less structured thoughts. I believe
      in learning in public: writing sharpens thinking, and sharing accelerates it.
    </p>
  </div>

  <div class="about-section">
    <h2>Interests</h2>
    <div class="interests-grid">
      <div class="interest-item">
        <h3>Geometric CV</h3>
        <p>Epipolar geometry, multi-view stereo, structure from motion, SLAM</p>
      </div>
      <div class="interest-item">
        <h3>3D Reconstruction</h3>
        <p>Neural radiance fields, Gaussian splatting, implicit representations</p>
      </div>
      <div class="interest-item">
        <h3>Depth Estimation</h3>
        <p>Monocular and stereo depth, self-supervised methods, metric depth</p>
      </div>
      <div class="interest-item">
        <h3>Optimization</h3>
        <p>Differentiable rendering, bundle adjustment, least squares on manifolds</p>
      </div>
    </div>
  </div>

  <div class="about-section">
    <h2>Get in Touch</h2>
    <p>I'm always happy to chat about computer vision, research ideas, or interesting problems.</p>
    <div class="contact-links">
      <a href="https://github.com/" class="contact-link">GitHub</a>
      <a href="https://scholar.google.com/" class="contact-link">Google Scholar</a>
      <a href="https://linkedin.com/" class="contact-link">LinkedIn</a>
      <a href="mailto:hello@example.com" class="contact-link">Email</a>
    </div>
  </div>
</Layout>
