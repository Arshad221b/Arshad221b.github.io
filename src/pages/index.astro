---
import Layout from '../layouts/Layout.astro';

const title = "Arshad Kazi";
---

<Layout title={title} activeNav="/">
  <div class="page-header">
    <h1>Arshad Kazi</h1>
    <p class="page-subtitle">Computer vision engineer. Interested in geometry, 3D understanding, and building things that see.</p>
  </div>

  <div class="about-intro">
    <p>
      I build computer vision systems &mdash; mostly around 3D understanding, pose estimation,
      and geometric reasoning. This site is where I write about the things I work on and
      occasionally think out loud.
    </p>
  </div>

  <div class="about-section">
    <h2>Interests</h2>
    <div class="interests-grid">
      <div class="interest-item">
        <h3>Geometric CV</h3>
        <p>Epipolar geometry, multi-view stereo, structure from motion, SLAM</p>
      </div>
      <div class="interest-item">
        <h3>3D Reconstruction</h3>
        <p>Neural radiance fields, Gaussian splatting, implicit representations</p>
      </div>
      <div class="interest-item">
        <h3>Depth Estimation</h3>
        <p>Monocular and stereo depth, self-supervised methods, metric depth</p>
      </div>
      <div class="interest-item">
        <h3>Optimization</h3>
        <p>Differentiable rendering, bundle adjustment, least squares on manifolds</p>
      </div>
    </div>
  </div>

  <div class="about-section">
    <h2>Get in Touch</h2>
    <p>I'm always happy to chat about computer vision, research ideas, or interesting problems.</p>
    <div class="contact-links">
      <a href="https://github.com/Arshad221b" class="contact-link" target="_blank">GitHub</a>
      <a href="https://www.linkedin.com/in/arshad221b/" class="contact-link" target="_blank">LinkedIn</a>
      <a href="mailto:arshadkaziblog@gmail.com" class="contact-link">Email</a>
    </div>
  </div>
</Layout>
