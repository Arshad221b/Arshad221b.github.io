---
import Layout from '../layouts/Layout.astro';

const title = "Arshad Kazi";

const cvProjects = [
  {
    title: "DINO from Scratch",
    description: "Full reimplementation of DINO (Self-Distillation with No Labels) using PyTorch and Vision Transformers. Contrast-free self-supervised learning with momentum encoders, centering, sharpening, and multi-view alignment.",
    image: "https://raw.githubusercontent.com/Arshad221b/DINO_from_scratch/main/screenshots/attention_maps.png",
    repo: "https://github.com/Arshad221b/DINO_from_scratch",
  },
  {
    title: "NeRF from Scratch",
    description: "PyTorch-based Neural Radiance Fields built entirely from scratch. Positional encoding, ray sampling, volume rendering, and novel view synthesis for 3D scene reconstruction.",
    image: "https://raw.githubusercontent.com/Arshad221b/NeRF-from-scratch/main/screenshot/nerf.png",
    repo: "https://github.com/Arshad221b/NeRF-from-scratch",
  },
  {
    title: "2D to 3D Human Pose Uplift",
    description: "Transformer-based system that lifts 2D pose keypoints to 3D, inspired by MotionBERT. Full training pipeline, temporal modeling, and 3D visualization.",
    image: "https://raw.githubusercontent.com/Arshad221b/2d_to_3d_pose_uplift/main/screenshot/Screenshot%202025-01-25%20at%203.18.19%E2%80%AFPM.png",
    repo: "https://github.com/Arshad221b/2d_to_3d_human_pose_uplift",
  },
  {
    title: "YOLO-NAS for Custom Dataset",
    description: "Fine-tuned YOLO-NAS on an Indian street sign dataset. Custom annotations, training scripts, and inference setup via SuperGradients.",
    image: "https://raw.githubusercontent.com/Arshad221b/YOLO-NAS-for-custom-data/main/demo/ezgif.com-video-to-gif.gif",
    repo: "https://github.com/Arshad221b/YOLO-NAS-for-custom-data",
  },
  {
    title: "3D U-Net for Image Segmentation",
    description: "Custom 3D U-Net for volumetric CT/MRI segmentation. Patch-wise training, organ-level labeling, and volumetric visualization.",
    repo: "https://github.com/Arshad221b/3D-UNet-Image-Segmentation",
  },
];

const nlpProjects = [
  {
    title: "RAG on PDF",
    description: "Retrieval-Augmented Generation pipeline that reads PDFs and answers natural language questions. Built with LangChain, FAISS, and LLMs with a focus on local-first privacy.",
    repo: "https://github.com/Arshad221b/RAG-on-PDF",
  },
  {
    title: "Named Entity Recognition",
    description: "NER system built using Huggingface's RoBERTa model. Token classification, training loop, data preprocessing, and clean inference pipeline.",
    repo: "https://github.com/Arshad221b/Named-Entity-Recognition",
  },
];
---

<Layout title={title} activeNav="/">
  <div class="hero-section">
    <div class="profile-image-wrapper">
      <img src="/images/profile.jpeg" alt="Arshad Kazi" class="profile-image" />
    </div>
    <div class="hero-text">
      <h1>Hi, I'm Arshad Kazi</h1>
      <p class="page-subtitle">Computer vision engineer. Interested in geometry, 3D understanding, and building things that see.</p>
    </div>
  </div>

  <div class="about-intro">
    <p>
      I'm a Computer Vision Engineer with industry experience. These are projects and experiments
      I do in my free time, purely out of interest. For professional info, see my
      <a href="https://www.linkedin.com/in/arshad221b/" target="_blank">LinkedIn</a>.
    </p>
    <p>
      I'm particularly interested in computer vision and multi-modal systems that understand
      the world by looking at it. I love understanding these systems from the inside out.
      Instead of just using models, I rebuild them to learn how they actually work.
    </p>
    <p>
      Most of my recent work explores self-supervision, pose estimation, image segmentation,
      and retrieval-augmented generation. I enjoy turning research into fully working
      systems &mdash; modular, testable, and often local-first.
    </p>
  </div>

  <hr />

  <div class="about-section">
    <h2>About Me</h2>
    <div class="about-details">
      <div class="detail-row">
        <span class="detail-label">Title</span>
        <span>Data Scientist</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Philosophy</span>
        <span>I'm all for ML models that can help us unravel the mysteries of the universe (not just generate adorable cat images)</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Interests</span>
        <span>Self-supervised learning, multimodal systems, human-centric AI, or anything that helps us understand how machines see the world</span>
      </div>
    </div>
  </div>

  <div class="about-section">
    <h2>Stuff I'm Kind of Good At</h2>
    <ul class="skills-list">
      <li>Rebuilding ML models from scratch (ViTs, DINO, UNet, etc.)</li>
      <li>Designing data pipelines that scale and debug well</li>
      <li>Self-supervised learning and training loops</li>
      <li>Fine-tuning large models with small data</li>
      <li>Keeping code readable, minimal, and modular</li>
      <li>Research work (finding papers for the solutions)</li>
    </ul>
  </div>

  <div class="about-section">
    <h2>Stuff I'm Trying to Get Better At</h2>
    <ul class="skills-list">
      <li>Multi-modal learning (vision + text + audio)</li>
      <li>Efficient training on low-resource hardware</li>
      <li>Generative modeling (audio, diffusion, NeRFs)</li>
      <li>Inference optimization (TensorRT, quantization)</li>
      <li>Better unit testing and CI/CD practices for ML pipelines</li>
      <li>Currently obsessed with geometric computer vision and want to get better at it</li>
    </ul>
  </div>

  <hr />

  <div class="about-section">
    <h2>Recent Computer Vision Projects</h2>
    <div class="projects-list">
      {cvProjects.map(project => (
        <a href={project.repo} class="project-card" target="_blank">
          {project.image && (
            <div class="project-image">
              <img src={project.image} alt={project.title} loading="lazy" />
            </div>
          )}
          <div class="project-info">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="about-section">
    <h2>NLP Projects</h2>
    <div class="projects-list">
      {nlpProjects.map(project => (
        <a href={project.repo} class="project-card" target="_blank">
          <div class="project-info">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <hr />

  <div class="about-section">
    <h2>Open To</h2>
    <ul class="skills-list">
      <li>Research collaborations in CV, SSL, pose estimation, segmentation</li>
      <li>Contract or freelance roles building full-stack ML systems</li>
      <li>Full-time roles in data science or ML engineering with depth and autonomy</li>
    </ul>
  </div>

  <div class="about-section">
    <h2>Get in Touch</h2>
    <div class="contact-links">
      <a href="https://github.com/Arshad221b" class="contact-link" target="_blank">GitHub</a>
      <a href="https://www.linkedin.com/in/arshad221b/" class="contact-link" target="_blank">LinkedIn</a>
      <a href="mailto:arshadkaziblog@gmail.com" class="contact-link">Email</a>
    </div>
  </div>
</Layout>
