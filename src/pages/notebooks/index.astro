---
import Layout from '../../layouts/Layout.astro';
import { days as neuroscienceDays } from '../../data/neuroscience-days';
import { days as emotionDays } from '../../data/emotion-days';
import { days as modernNetsDays } from '../../data/modern-nets-days';
import { days as vlmSearchDays } from '../../data/vlm-search-days';
import { entries as slamEntries, months as slamMonths } from '../../data/slam-entries';


const title = "Notebooks — Arshad Kazi";

const longRunning = [
  {
    title: "SLAM from Scratch",
    slug: "slam",
    duration: "6 months",
    commitment: "whenever it happens",
    status: "active" as const,
    startDate: "2026-05-13",
    description: "Building a full SLAM pipeline from scratch. Camera models, feature extraction, matching, motion estimation, mapping, loop closure, graph optimization. Theory and code, no shortcuts.",
    tags: ["computer vision", "robotics", "geometry"],
    entryCount: slamEntries.length,
    months: slamMonths,
    entries: slamEntries,
  },
];

function getEntriesForMonth(entries: typeof slamEntries, month: string) {
  return entries.filter(e => e.date.startsWith(month));
}

function formatMonthShort(monthStr: string): string {
  const date = new Date(monthStr + '-01T00:00:00');
  return date.toLocaleDateString('en-US', { month: 'short' });
}

const experiments = [
  {
    title: "Overview of Modern Nets",
    slug: "modern-nets",
    totalDays: 7,
    completedDays: 7,
    commitment: "1 hr / day",
    status: "completed" as const,
    startDate: "2026-04-27",
    endDate: "2026-05-05",
    description: "Revisiting transformers, tokenizers, attention, and the GPT family. Intuitive understanding for interviews and curiosity.",
    conclusion: "Everything builds on the same transformer attention mechanism. From BPE tokenization to multi-head attention to the full GPT family. The ecosystem on top (RAG, LangChain, agents) is plumbing to make it useful. Still want to go deeper on RoPE, SwiGLU, the chain of thought paper, and diffusion models.",
    tags: ["deep learning", "transformers", "LLMs"],
  },
  {
    title: "Search Images with Words",
    slug: "vlm-search",
    totalDays: 4,
    completedDays: 4,
    commitment: "1 hr / day, weekdays",
    status: "completed" as const,
    startDate: "2026-03-30",
    endDate: "2026-04-04",
    description: "From neuroscience to CLIP to building a working on-device search prototype. How do VLMs bind words to pixels?",
    conclusion: "Went from the CLIP paper to a working implementation from scratch. Two encoders, one shared embedding space, contrastive loss. The key insight is that aligning text and image representations lets you do zero-shot classification and text-to-image search without task-specific training.",
    tags: ["computer vision", "machine learning", "multimodal"],
  },
  {
    title: "Understanding Emotion",
    slug: "emotion",
    totalDays: 7,
    completedDays: 7,
    commitment: "1 hr / day",
    status: "completed" as const,
    startDate: "2026-03-28",
    endDate: "2026-04-09",
    description: "What are emotions, really? The neuroscience of feeling, and why an autistic brain might process them differently.",
    conclusion: "Nobody agrees on what emotions are, but evolution built them for a reason. Basic emotions are universal biology. Higher cognitive emotions like guilt are trust signals. Happiness comes from relationships, not money. Emotions actively distort memory, attention, and judgement. Empathy is not mirroring, it is feeling what others feel. The people we need are those who can manage it.",
    tags: ["neuroscience", "psychology", "autism"],
  },
  {
    title: "Understanding the Visual Cortex",
    slug: "neuroscience",
    totalDays: 7,
    completedDays: 7,
    commitment: "1 hr / day",
    status: "completed" as const,
    startDate: "2026-03-21",
    endDate: "2026-03-27",
    description: "How does the brain process what the eye sees? Tracing the path from retina through two parallel streams, the mechanisms at each stage, and the computations behind perception.",
    conclusion: "The brain doesn't see the world as it is. It builds a model of what the world should be, and checks it against incoming data. The whole journey, from photon hitting the retina to a fully contextualised, emotionally-tagged memory, takes roughly 150 milliseconds.",
    tags: ["neuroscience", "perception", "visual cortex"],
  },
];

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Layout title={title} activeNav="/notebooks" description="Time-boxed deep dives into topics I'm curious about. Pick a question, spend a week on it, write what I learn." ogImage="/images/og-thoughts.jpg">
  <div class="te-page">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      <span>Time-boxed Inquiry</span>
    </div>

    <div class="page-header">
      <h1>Notebooks</h1>
    </div>

    <div class="te-intro-box">
      <div class="intro-grid">
        <div class="intro-block">
          <h2>The why</h2>
          <p>Transfer learning works in brains too. Neuroscience research shows that learning across domains strengthens abstract reasoning. The prefrontal cortex builds schema, mental frameworks that compress patterns from one domain and apply them to another. The more domains you feed it, the richer the schema. Convolutions in V1 and convolutions in CNNs are the same idea discovered independently. Attention in the parietal cortex and attention in transformers solve the same resource allocation problem. These are not metaphors. They are convergent solutions.</p>
          <p>Leonardo da Vinci studied anatomy to paint better and painted to understand anatomy better. Feynman learned to pick locks to understand information theory. Ramanujan found number theory in temple floor patterns. Cross-domain learning is not a distraction from depth. It is how depth actually works.</p>
        </div>

        <div class="intro-block">
          <h2>The practice</h2>
          <p>Spaced repetition research shows that retrieval under time pressure consolidates memory faster than passive review. The hippocampus encodes better when the learning session has a clear boundary. One question, one week, one hour per day. The constraint forces active recall. You cannot passively read for sixty minutes and pretend you understood it. You have to write what you know, find the gaps, and come back the next day to fill them.</p>
          <p>I am a Leonardo fanboy, not because I think I am smart like him because I am really not, but because the man had no formal education past age 14 and still taught himself anatomy and optics and geology and engineering from whatever books and mentors he could get his hands on, and that is the only way I have ever been able to learn anything either. He kept notebooks his entire life, thousands of pages, anatomy next to fluid dynamics next to machine designs, not organized by subject but by date, and he called himself "discepolo della esperienza" which means disciple of experience, and I think the notebook was never documentation for him, it was the actual thinking tool, the place where looking at something carefully enough turns into understanding it.</p>
        </div>
      </div>
    </div>

    <div class="section-header">
      <span class="section-label">Running</span>
      <span class="section-count">{experiments.filter(e => e.status === 'active').length + longRunning.length}</span>
    </div>

    <div class="experiments-grid">
      {longRunning.map(proj => (
        <a href={`/notebooks/${proj.slug}`} class="exp-card">
          <div class="exp-card-glow"></div>
          <div class="exp-card-content">
            <div class="exp-card-header">
              <span class="exp-badge active">{proj.entryCount} {proj.entryCount === 1 ? 'entry' : 'entries'}</span>
              <span class="exp-commitment">{proj.duration} &middot; {proj.commitment}</span>
            </div>
            <h3>{proj.title}</h3>
            <p>{proj.description}</p>
            <div class="lr-month-strip">
              {proj.months.map(month => {
                const count = getEntriesForMonth(proj.entries, month);
                return (
                  <div class={`lr-month ${count.length > 0 ? 'has-entries' : ''}`}>
                    <span class="lr-month-label">{formatMonthShort(month)}</span>
                    {count.length > 0 && <span class="lr-month-count">{count.length}</span>}
                  </div>
                );
              })}
            </div>
            <div class="exp-card-footer">
              <div class="exp-tags">
                {proj.tags.map(tag => (
                  <span class="exp-tag">{tag}</span>
                ))}
              </div>
              <span class="exp-date">Started {formatDate(proj.startDate)}</span>
            </div>
          </div>
        </a>
      ))}

      {experiments.filter(e => e.status === 'active').map(exp => (
        <a href={`/notebooks/${exp.slug}`} class="exp-card">
          <div class="exp-card-glow"></div>
          <div class="exp-card-content">
            <div class="exp-card-header">
              <span class="exp-badge active">Day {exp.completedDays}/{exp.totalDays}</span>
              <span class="exp-commitment">{exp.commitment}</span>
            </div>
            <h3>{exp.title}</h3>
            <p>{exp.description}</p>
            <div class="exp-progress">
              {Array.from({length: exp.totalDays}).map((_, i) => (
                <span class={`exp-dot ${i < exp.completedDays ? 'filled' : ''}`} />
              ))}
            </div>
            <div class="exp-card-footer">
              <div class="exp-tags">
                {exp.tags.map(tag => (
                  <span class="exp-tag">{tag}</span>
                ))}
              </div>
              <span class="exp-date">Started {formatDate(exp.startDate)}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="section-header">
      <span class="section-label">Completed</span>
    </div>

    <div class="experiments-grid">
      {experiments.filter(e => e.status === 'completed').map(exp => {
        const days = exp.slug === 'neuroscience' ? neuroscienceDays : exp.slug === 'emotion' ? emotionDays : exp.slug === 'modern-nets' ? modernNetsDays : exp.slug === 'vlm-search' ? vlmSearchDays : [];
        const activeDays = days.filter(d => d.curiosityTitle);
        return (
        <a href={`/notebooks/${exp.slug}`} class="exp-card completed">
          <div class="exp-card-content">
            <div class="exp-card-header">
              <span class="exp-badge done">{exp.totalDays} days</span>
              <span class="exp-commitment">{exp.commitment}</span>
            </div>
            <h3>{exp.title}</h3>
            <p>{exp.description}</p>
            
            {exp.conclusion && (
              <div class="exp-conclusion">
                <p>{exp.conclusion}</p>
              </div>
            )}

            <div class="exp-timeline">
              <span class="timeline-label">The journey</span>
              <div class="timeline-steps">
                {activeDays.map((d) => (
                  <div class="timeline-step">
                    <span class="timeline-num">{d.day}</span>
                    <span class="timeline-q">{d.curiosityTitle}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="exp-card-footer">
              <div class="exp-tags">
                {exp.tags.map(tag => (
                  <span class="exp-tag">{tag}</span>
                ))}
              </div>
              <span class="exp-cta">Read the full experiment</span>
            </div>
          </div>
        </a>
      );})}
    </div>

  </div>
</Layout>

<style>
  .te-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .te-intro-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-md);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .intro-block h2 {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .intro-block p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 var(--space-sm) 0;
  }

  .intro-block p:last-child {
    margin-bottom: 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .section-count {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    background: var(--color-accent);
    color: white;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
  }

  .experiments-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .exp-card {
    position: relative;
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-md);
    text-decoration: none;
    overflow: hidden;
    transition: all 0.25s ease;
  }

  .exp-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(196, 116, 63, 0.12);
    text-decoration: none;
  }

  .exp-card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-hover));
  }

  .exp-card.completed .exp-card-glow {
    background: linear-gradient(90deg, var(--color-text-muted), var(--color-text-secondary));
  }

  .exp-card-content {
    position: relative;
  }

  .exp-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xs);
  }

  .exp-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }

  .exp-badge.active {
    background: var(--color-accent);
    color: white;
  }

  .exp-badge.done {
    background: var(--color-tag-bg);
    color: var(--color-text-secondary);
  }

  .exp-commitment {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .exp-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-xs) 0;
  }

  .exp-card > .exp-card-content > p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0 0 var(--space-sm) 0;
  }

  .exp-progress {
    display: flex;
    gap: 3px;
    margin-bottom: var(--space-sm);
  }

  .exp-dot {
    width: 10px;
    height: 3px;
    background: var(--color-border);
    border-radius: 2px;
  }

  .exp-dot.filled {
    background: var(--color-accent);
  }

  .exp-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .exp-tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .exp-tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }

  .exp-date {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .exp-cta {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .exp-card:hover .exp-cta {
    text-decoration: underline;
  }

  .exp-conclusion {
    padding: var(--space-sm);
    background: var(--color-accent-soft);
    border-radius: 6px;
    margin-bottom: var(--space-sm);
  }

  .exp-conclusion p {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-text);
    margin: 0;
    line-height: 1.7;
  }

  .exp-timeline {
    margin-bottom: var(--space-sm);
  }

  .timeline-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .timeline-steps {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .timeline-step {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 0.2rem 0.4rem;
    background: var(--color-tag-bg);
    border-radius: 3px;
  }

  .timeline-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .timeline-q {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-text-secondary);
  }

  .lr-month-strip {
    display: flex;
    gap: 3px;
    margin-bottom: var(--space-sm);
  }

  .lr-month {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    flex: 1;
    padding: 0.3rem 0.2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .lr-month.has-entries {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .lr-month-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .lr-month.has-entries .lr-month-label {
    color: var(--color-accent);
  }

  .lr-month-count {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
