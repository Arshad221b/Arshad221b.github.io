---
import Layout from '../../../layouts/Layout.astro';
import { experiment, days } from '../../../data/neuroscience-days';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return days
    .filter(d => d.bullets.length > 0)
    .map(d => ({ params: { day: `day-${d.day}` }, props: { dayData: d } }));
};

const { dayData: day } = Astro.props;

const title = `Day ${day.day}: ${day.curiosityTitle} — Understanding the Visual Cortex — Arshad Kazi`;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

const activeDays = days.filter(d => d.bullets.length > 0);
const currentIndex = activeDays.findIndex(d => d.day === day.day);
const prevDay = currentIndex > 0 ? activeDays[currentIndex - 1] : null;
const nextDay = currentIndex < activeDays.length - 1 ? activeDays[currentIndex + 1] : null;
---

<Layout title={title} activeNav="/notebooks" description={`Day ${day.day}: ${day.curiosityTitle}`} ogImage="/images/og-tiny-experiments.jpg">
  <div class="experiment-page">
    <a href="/notebooks/neuroscience" class="back-link">&larr; All Days</a>

    <div class="day-page-header">
      <span class="day-page-number">Day {day.day} &mdash; {formatDate(day.date)}</span>
      <h1 class="day-page-title">{day.curiosityTitle}</h1>
    </div>

    <div class="day-entry">
      {day.bullets && day.bullets.length > 0 && (
        <ul class="day-bullets">
          {day.bullets.map(bullet => (
            <li>{bullet}</li>
          ))}
        </ul>
      )}

      {day.showStreamDiagrams && day.sections && (
        <div class="stream-diagrams">
          <div class="stream-diagram">
            <h4 class="diagram-title">Dorsal Stream — "Where / How"</h4>
            <div class="flow">
              <div class="flow-step"><span class="flow-node">Retina</span></div>
              <div class="flow-step"><span class="flow-node">V1</span></div>
              <div class="flow-step"><span class="flow-node">V2 / V3</span></div>
              <div class="flow-step"><span class="flow-node">MT / V5</span><span class="flow-label">motion energy</span></div>
              <div class="flow-step"><span class="flow-node">MST</span><span class="flow-label">optical flow</span></div>
              <div class="flow-step"><span class="flow-node">PPC</span><span class="flow-label">predictive coding</span></div>
              <div class="flow-step flow-fork">
                <span class="flow-node">Motor cortex</span>
                <span class="flow-node">Frontal eye field</span>
                <span class="flow-label">efference copy</span>
              </div>
            </div>
          </div>

          <div class="stream-diagram">
            <h4 class="diagram-title">Ventral Stream — "What"</h4>
            <div class="flow">
              <div class="flow-step"><span class="flow-node">Retina</span></div>
              <div class="flow-step"><span class="flow-node">LGN</span></div>
              <div class="flow-step"><span class="flow-node">V1</span><span class="flow-label">fine detail, colour, high freq</span></div>
              <div class="flow-step"><span class="flow-node">V2</span><span class="flow-label">contours, figure-ground, illusionary edges</span></div>
              <div class="flow-step"><span class="flow-node">V4</span><span class="flow-label">shapes, colour constancy, curves</span></div>
              <div class="flow-step"><span class="flow-node">IT (posterior)</span><span class="flow-label">complex shapes</span></div>
              <div class="flow-step"><span class="flow-node">Anterior IT</span><span class="flow-label">recognition</span></div>
              <div class="flow-step flow-fork">
                <span class="flow-node">Amygdala</span>
                <span class="flow-node">Hippocampus</span>
                <span class="flow-label">emotional relevance &amp; contextual memory</span>
              </div>
            </div>
          </div>
        </div>
      )}

      {day.sections && day.sections.map(section => (
        <div class="day-section">
          <h4 class="section-heading">{section.title}</h4>
          {section.subtitle && <p class="section-subtitle">{section.subtitle}</p>}

          {section.showContextDiagram && (
            <div class="mini-diagram context-diagram">
              <div class="ctx-row">
                <span class="ctx-neuron ctx-neighbour" title="Neighbour neuron (45°)">45°</span>
                <span class="ctx-arrow">⟷</span>
                <span class="ctx-neuron ctx-center" title="Central neuron (45°)">45°</span>
                <span class="ctx-arrow">⟷</span>
                <span class="ctx-neuron ctx-neighbour" title="Neighbour neuron (45°)">45°</span>
              </div>
              <div class="ctx-caption">horizontal connections between same-orientation neurons</div>
              <div class="ctx-example">
                <div class="ctx-example-item">
                  <span class="ctx-signal ctx-signal-noise">~ ~ ~</span>
                  <span class="ctx-result">neighbours quiet → fire stronger ✓ real edge</span>
                </div>
                <div class="ctx-example-item">
                  <span class="ctx-signal ctx-signal-active">↗ ↗ ↗</span>
                  <span class="ctx-result">neighbours active → noise, suppress</span>
                </div>
              </div>
            </div>
          )}

          {section.showInhibitoryDiagram && (
            <div class="mini-diagram inhibitory-diagram">
              <div class="inhib-bar">
                <span class="inhib-zone inhib-end" title="Inhibitory zone">−</span>
                <span class="inhib-zone inhib-excite" title="Excitatory zone">＋ receptive field ＋</span>
                <span class="inhib-zone inhib-end" title="Inhibitory zone">−</span>
              </div>
              <div class="inhib-examples">
                <div class="inhib-case">
                  <span class="inhib-line inhib-short">———</span>
                  <span class="ctx-result">short line → strong fire (object edge)</span>
                </div>
                <div class="inhib-case">
                  <span class="inhib-line inhib-long">————————————</span>
                  <span class="ctx-result">long line → weak fire (likely background)</span>
                </div>
              </div>
            </div>
          )}

          {section.showDepthNeuronsDiagram && (
            <div class="mini-diagram depth-neurons-diagram">
              <div class="dn-grid">
                <div class="dn-card">
                  <div class="dn-label">Tuned Excitatory</div>
                  <div class="dn-bar-row">
                    <span class="dn-depth-label">near</span>
                    <div class="dn-bar-track"><div class="dn-bar dn-bar-excitatory" style="width:12%; margin-left:55%"></div></div>
                    <span class="dn-depth-label">far</span>
                  </div>
                  <div class="dn-hint">fires at one specific depth only</div>
                </div>
                <div class="dn-card">
                  <div class="dn-label">Tuned Inhibitory</div>
                  <div class="dn-bar-row">
                    <span class="dn-depth-label">near</span>
                    <div class="dn-bar-track">
                      <div class="dn-bar dn-bar-inhibitory-left" style="width:42%"></div>
                      <div class="dn-bar-gap" style="width:14%"></div>
                      <div class="dn-bar dn-bar-inhibitory-right" style="width:44%"></div>
                    </div>
                    <span class="dn-depth-label">far</span>
                  </div>
                  <div class="dn-hint">silent at fixation plane, fires everywhere else</div>
                </div>
                <div class="dn-card">
                  <div class="dn-label">Near / Far Cells</div>
                  <div class="dn-bar-row">
                    <span class="dn-depth-label">near</span>
                    <div class="dn-bar-track">
                      <div class="dn-bar dn-bar-near" style="width:45%"></div>
                      <div class="dn-bar-gap" style="width:10%"></div>
                      <div class="dn-bar dn-bar-far" style="width:45%"></div>
                    </div>
                    <span class="dn-depth-label">far</span>
                  </div>
                  <div class="dn-hint-row">
                    <span class="dn-hint">← near cells</span>
                    <span class="dn-hint">far cells →</span>
                  </div>
                </div>
              </div>
            </div>
          )}

          {section.showAmodalDiagram && (
            <div class="mini-diagram amodal-diagram">
              <div class="amodal-panels">
                <div class="amodal-panel">
                  <div class="amodal-panel-label">Left eye sees</div>
                  <div class="amodal-panel-scene">
                    <div class="amodal-book-part amodal-book-hidden"></div>
                    <div class="amodal-cup-block"></div>
                    <div class="amodal-book-part amodal-book-visible"></div>
                  </div>
                  <div class="amodal-panel-desc">right side visible, left hidden by cup</div>
                </div>
                <div class="amodal-plus">+</div>
                <div class="amodal-panel">
                  <div class="amodal-panel-label">Right eye sees</div>
                  <div class="amodal-panel-scene">
                    <div class="amodal-book-part amodal-book-visible"></div>
                    <div class="amodal-cup-block"></div>
                    <div class="amodal-book-part amodal-book-hidden"></div>
                  </div>
                  <div class="amodal-panel-desc">left side visible, right hidden by cup</div>
                </div>
                <div class="amodal-equals">=</div>
                <div class="amodal-panel amodal-panel-result">
                  <div class="amodal-panel-label amodal-label-brain">Brain perceives</div>
                  <div class="amodal-panel-scene">
                    <div class="amodal-book-full"></div>
                    <div class="amodal-cup-front"></div>
                  </div>
                  <div class="amodal-panel-desc amodal-desc-result">one complete book — gap filled in</div>
                </div>
              </div>
            </div>
          )}

          {section.showKaniszaDiagram && (
            <div class="mini-diagram kanisza-diagram">
              <div class="kanisza-container">
                <div class="kanisza-pac kanisza-pos-top"></div>
                <div class="kanisza-pac kanisza-pos-bl"></div>
                <div class="kanisza-pac kanisza-pos-br"></div>
              </div>
              <div class="ctx-caption">no edges drawn — yet you see a triangle</div>
            </div>
          )}

          {section.showDisparityCaptDiagram && (
            <div class="mini-diagram disparity-diagram">
              <div class="disp-surface">
                <div class="disp-region disp-ambiguous">?</div>
                <div class="disp-region disp-ambiguous">?</div>
                <div class="disp-region disp-confident">
                  <span class="disp-conf-label">high<br/>confidence</span>
                </div>
                <div class="disp-region disp-ambiguous">?</div>
                <div class="disp-region disp-ambiguous">?</div>
              </div>
              <div class="disp-arrows">
                <span class="disp-arrow-left">← ← propagate</span>
                <span class="disp-arrow-center">●</span>
                <span class="disp-arrow-right">propagate → →</span>
              </div>
              <div class="ctx-caption">depth estimates spread outward from high-confidence anchor points</div>
            </div>
          )}

          {section.showDaVinciDiagram && (
            <div class="mini-diagram davinci-diagram">
              <div class="dv-scene">
                <svg class="dv-svg" viewBox="0 0 340 220">
                  {/* Background wall */}
                  <rect x="40" y="10" width="260" height="40" rx="3" fill="var(--color-border)" stroke="var(--color-text-muted)" stroke-width="1"/>
                  <text x="170" y="34" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-muted)">background wall</text>

                  {/* Hidden regions */}
                  <rect x="80" y="10" width="30" height="40" rx="0" fill="var(--color-accent)" opacity="0.25"/>
                  <text x="95" y="34" text-anchor="middle" font-family="var(--font-mono)" font-size="8" font-weight="700" fill="var(--color-accent)">L</text>
                  <rect x="230" y="10" width="30" height="40" rx="0" fill="var(--color-accent)" opacity="0.25"/>
                  <text x="245" y="34" text-anchor="middle" font-family="var(--font-mono)" font-size="8" font-weight="700" fill="var(--color-accent)">R</text>

                  {/* Occluder */}
                  <rect x="120" y="70" width="100" height="50" rx="5" fill="var(--color-text)" opacity="0.85"/>
                  <text x="170" y="100" text-anchor="middle" font-family="var(--font-mono)" font-size="11" font-weight="700" fill="var(--color-bg)">occluder</text>

                  {/* Sight lines from left eye */}
                  <line x1="120" y1="200" x2="120" y2="70" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="4,3" opacity="0.5"/>
                  <line x1="120" y1="200" x2="260" y2="10" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="4,3" opacity="0.5"/>

                  {/* Sight lines from right eye */}
                  <line x1="220" y1="200" x2="220" y2="70" stroke="var(--color-text-muted)" stroke-width="1" stroke-dasharray="4,3" opacity="0.5"/>
                  <line x1="220" y1="200" x2="80" y2="10" stroke="var(--color-text-muted)" stroke-width="1" stroke-dasharray="4,3" opacity="0.5"/>

                  {/* Eyes */}
                  <ellipse cx="120" cy="205" rx="14" ry="10" fill="var(--color-accent)" opacity="0.9"/>
                  <text x="120" y="209" text-anchor="middle" font-family="var(--font-mono)" font-size="8" font-weight="700" fill="var(--color-bg)">L</text>
                  <ellipse cx="220" cy="205" rx="14" ry="10" fill="var(--color-text-muted)" opacity="0.7"/>
                  <text x="220" y="209" text-anchor="middle" font-family="var(--font-mono)" font-size="8" font-weight="700" fill="var(--color-bg)">R</text>

                  {/* ~6cm label */}
                  <line x1="134" y1="205" x2="206" y2="205" stroke="var(--color-text-muted)" stroke-width="1"/>
                  <text x="170" y="218" text-anchor="middle" font-family="var(--font-mono)" font-size="7" fill="var(--color-text-muted)">~6 cm</text>

                  {/* Annotations */}
                  <text x="58" y="64" text-anchor="start" font-family="var(--font-sans)" font-size="8" fill="var(--color-accent)" font-style="italic">only right</text>
                  <text x="58" y="72" text-anchor="start" font-family="var(--font-sans)" font-size="8" fill="var(--color-accent)" font-style="italic">eye sees this</text>
                  <text x="282" y="64" text-anchor="end" font-family="var(--font-sans)" font-size="8" fill="var(--color-accent)" font-style="italic">only left</text>
                  <text x="282" y="72" text-anchor="end" font-family="var(--font-sans)" font-size="8" fill="var(--color-accent)" font-style="italic">eye sees this</text>
                </svg>
              </div>
              <div class="dv-insight">
                <span class="dv-insight-label">Key insight:</span> Each eye sees a sliver of background the other can't — the occluded region itself becomes a depth signal. No feature matching needed — absence of information = depth.
              </div>
            </div>
          )}

          {section.showBorderOwnershipDiagram && (
            <div class="mini-diagram border-ownership-diagram">
              <div class="bo-scene">
                <div class="bo-surface">
                  <div class="bo-dot">
                    <div class="bo-arrow bo-arrow-top">↑</div>
                    <div class="bo-arrow bo-arrow-right">→</div>
                    <div class="bo-arrow bo-arrow-bottom">↓</div>
                    <div class="bo-arrow bo-arrow-left">←</div>
                  </div>
                </div>
              </div>
              <div class="bo-legend">
                <span class="bo-legend-item"><span class="bo-swatch bo-swatch-dot"></span> figure (owns the border)</span>
                <span class="bo-legend-item"><span class="bo-swatch bo-swatch-bg"></span> ground (continues behind)</span>
              </div>
            </div>
          )}

          {section.showBrightnessDiagram && (
            <div class="mini-diagram brightness-diagram">
              <div class="bright-compare">
                <div class="bright-card bright-card-light">
                  <div class="bright-box"></div>
                  <span class="bright-label">looks darker</span>
                </div>
                <div class="bright-vs">=</div>
                <div class="bright-card bright-card-dark">
                  <div class="bright-box"></div>
                  <span class="bright-label">looks lighter</span>
                </div>
              </div>
              <div class="ctx-caption">same grey — different perception depending on background</div>
            </div>
          )}

          {section.showReceptiveFieldDiagram && (
            <div class="mini-diagram rf-diagram">
              <div class="rf-compare">
                <div class="rf-card">
                  <div class="rf-visual">
                    <div class="rf-field rf-classical">
                      <span class="rf-dot">●</span>
                    </div>
                  </div>
                  <div class="rf-card-label">Classical</div>
                  <div class="rf-card-desc">responds only to own field</div>
                </div>
                <div class="rf-arrow">→</div>
                <div class="rf-card">
                  <div class="rf-visual">
                    <div class="rf-field rf-nonclassical">
                      <div class="rf-field rf-classical rf-inner">
                        <span class="rf-dot">●</span>
                      </div>
                    </div>
                  </div>
                  <div class="rf-card-label">Non-Classical</div>
                  <div class="rf-card-desc">influenced by surround via horizontal connections</div>
                </div>
              </div>
            </div>
          )}

          {section.showPopOutDiagram && (
            <div class="mini-diagram popout-diagram">
              <div class="popout-compare">
                <div class="popout-card">
                  <div class="popout-grid">
                    <span class="popout-dot popout-yellow">●</span>
                    <span class="popout-dot popout-yellow">●</span>
                    <span class="popout-dot popout-red">●</span>
                    <span class="popout-dot popout-yellow">●</span>
                    <span class="popout-dot popout-yellow">●</span>
                    <span class="popout-dot popout-yellow">●</span>
                    <span class="popout-dot popout-yellow">●</span>
                    <span class="popout-dot popout-yellow">●</span>
                    <span class="popout-dot popout-yellow">●</span>
                  </div>
                  <div class="popout-label popout-label-fast">instant pop-out ✓</div>
                </div>
                <div class="popout-card">
                  <div class="popout-grid popout-grid-text">
                    <span class="popout-char">6</span>
                    <span class="popout-char">6</span>
                    <span class="popout-char">6</span>
                    <span class="popout-char">9</span>
                    <span class="popout-char">6</span>
                    <span class="popout-char">6</span>
                    <span class="popout-char">6</span>
                    <span class="popout-char">6</span>
                    <span class="popout-char">6</span>
                  </div>
                  <div class="popout-label popout-label-slow">serial search needed ✗</div>
                </div>
              </div>
            </div>
          )}

          {section.showHighLevelPipelineDiagram && (
            <div class="mini-diagram pipeline-diagram">
              <div class="pipeline-flow">
                <div class="pipeline-stage">
                  <div class="pipeline-node pipeline-node-v4">V4</div>
                  <div class="pipeline-desc">shape, colour constancy<br/>invariance begins</div>
                </div>
                <div class="pipeline-connector">→</div>
                <div class="pipeline-stage">
                  <div class="pipeline-node pipeline-node-pit">Posterior IT</div>
                  <div class="pipeline-desc">complete object<br/>representation (perception)</div>
                </div>
                <div class="pipeline-connector">→</div>
                <div class="pipeline-stage">
                  <div class="pipeline-node pipeline-node-ait">Anterior IT</div>
                  <div class="pipeline-desc">percepts connect<br/>to meaning</div>
                </div>
                <div class="pipeline-connector">→</div>
                <div class="pipeline-stage">
                  <div class="pipeline-node pipeline-node-final">Amygdala / Hippo</div>
                  <div class="pipeline-desc">vision becomes<br/>cognition</div>
                </div>
              </div>
              <div class="pipeline-spectrum">
                <span class="pipeline-spectrum-left">features</span>
                <div class="pipeline-spectrum-bar"></div>
                <span class="pipeline-spectrum-right">meaning</span>
              </div>
            </div>
          )}

          {section.showV4FunctionsDiagram && (
            <div class="mini-diagram v4-functions-diagram">
              <div class="v4f-grid">
                <div class="v4f-card">
                  <div class="v4f-number">1</div>
                  <div class="v4f-title">Colour Constancy</div>
                  <div class="v4f-visual">
                    <div class="v4f-color-demo">
                      <div class="v4f-color-ctx v4f-ctx-warm">
                        <div class="v4f-color-apple"></div>
                        <span class="v4f-ctx-label">sunlight</span>
                      </div>
                      <span class="v4f-equals">=</span>
                      <div class="v4f-color-ctx v4f-ctx-cool">
                        <div class="v4f-color-apple"></div>
                        <span class="v4f-ctx-label">fluorescent</span>
                      </div>
                    </div>
                  </div>
                  <div class="v4f-desc">factors out illumination — computes colour relative to surroundings</div>
                </div>
                <div class="v4f-card">
                  <div class="v4f-number">2</div>
                  <div class="v4f-title">Shape & Curves</div>
                  <div class="v4f-visual">
                    <div class="v4f-shapes">
                      <svg class="v4f-shape-svg" viewBox="0 0 60 40">
                        <path d="M5,35 Q15,5 30,20 Q45,35 55,10" fill="none" stroke="currentColor" stroke-width="2"/>
                      </svg>
                      <svg class="v4f-shape-svg" viewBox="0 0 60 40">
                        <path d="M10,30 L25,8 L40,30 L55,15" fill="none" stroke="currentColor" stroke-width="2"/>
                      </svg>
                    </div>
                  </div>
                  <div class="v4f-desc">extracts geometric properties — contours, curves, angles</div>
                </div>
                <div class="v4f-card">
                  <div class="v4f-number">3</div>
                  <div class="v4f-title">Invariance Begins</div>
                  <div class="v4f-visual">
                    <div class="v4f-invariance">
                      <span class="v4f-inv-shape">&#9651;</span>
                      <span class="v4f-inv-shape v4f-inv-small">&#9651;</span>
                      <span class="v4f-inv-shape v4f-inv-rotated">&#9651;</span>
                      <span class="v4f-inv-approx">≈</span>
                    </div>
                  </div>
                  <div class="v4f-desc">small changes in position, rotation & size are tolerated</div>
                </div>
              </div>
              <div class="v4f-damage">
                <span class="v4f-damage-label">V4 damaged →</span> achromatopsia: total loss of colour, everything else survives
              </div>
            </div>
          )}

          {section.showITColumnDiagram && (
            <div class="mini-diagram it-column-diagram">
              <div class="itc-compare">
                <div class="itc-panel">
                  <div class="itc-panel-label">V1 Columns (Distinct)</div>
                  <div class="itc-columns itc-v1">
                    <div class="itc-col itc-col-a">
                      <span class="itc-col-label">45°</span>
                    </div>
                    <div class="itc-col itc-col-b">
                      <span class="itc-col-label">90°</span>
                    </div>
                    <div class="itc-col itc-col-c">
                      <span class="itc-col-label">135°</span>
                    </div>
                  </div>
                  <div class="itc-hint">hard borders between columns</div>
                </div>
                <div class="itc-vs">vs</div>
                <div class="itc-panel">
                  <div class="itc-panel-label">IT Columns (Overlapping)</div>
                  <div class="itc-columns itc-it">
                    <div class="itc-col-overlap itc-overlap-a">
                      <span class="itc-col-label">face</span>
                    </div>
                    <div class="itc-col-overlap itc-overlap-b">
                      <span class="itc-col-label">hand</span>
                    </div>
                    <div class="itc-col-overlap itc-overlap-c">
                      <span class="itc-col-label">body</span>
                    </div>
                  </div>
                  <div class="itc-hint">columns blend — shared knowledge</div>
                </div>
              </div>
              <div class="itc-stat">
