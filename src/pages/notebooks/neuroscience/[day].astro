                <text x="340" y="720" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-text-muted)">Complete object representation — not features, but things</text>
                <text x="340" y="737" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-text-muted)">Cortical columns (~400 μm wide) that overlap and share knowledge</text>
                <text x="340" y="754" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-text-muted)">Population coding: firing pattern across neurons = vector embedding</text>
                <text x="340" y="768" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-text-muted)">Full invariance: same neuron fires regardless of size, position, rotation</text>
                <text x="340" y="782" text-anchor="middle" font-family="var(--font-sans)" font-size="9" font-style="italic" fill="var(--color-text-muted)">Face-selective regions · long-range horizontal connections · ~30,000 objects from shared columns</text>

                {/* Arrow */}
                <line x1="340" y1="788" x2="340" y2="814" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="335,811 340,820 345,811" fill="var(--color-accent)"/>

                {/* ── Stage 6: Anterior IT ── */}
                <rect x="80" y="820" width="520" height="108" rx="8" fill="var(--color-accent-soft)" stroke="var(--color-accent)" stroke-width="2"/>
                <text x="340" y="844" text-anchor="middle" font-family="var(--font-mono)" font-size="15" font-weight="700" fill="var(--color-accent)">Anterior IT — Semantic Binding</text>
                <text x="340" y="864" text-anchor="middle" font-family="var(--font-sans)" font-size="11" font-weight="600" fill="var(--color-text-muted)">Where seeing becomes knowing</text>
                <text x="340" y="882" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-text-muted)">Connects percepts to stored semantic knowledge and memory</text>
                <text x="340" y="899" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-text-muted)">"I see a face" → "this is my mother" — perception meets meaning</text>
                <text x="340" y="913" text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--color-text-muted)">Category-specific regions: living vs non-living, faces vs tools vs places</text>
                <text x="340" y="925" text-anchor="middle" font-family="var(--font-sans)" font-size="9" font-style="italic" fill="var(--color-text-muted)">Damage → associative agnosia (can't name) · prosopagnosia (face identity)</text>

                {/* Fork arrows */}
                <line x1="220" y1="928" x2="160" y2="964" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="158,958 156,968 166,964" fill="var(--color-accent)"/>
                <line x1="460" y1="928" x2="520" y2="964" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="514,964 524,968 522,958" fill="var(--color-accent)"/>

                {/* ── Output 1: Amygdala ── */}
                <rect x="20" y="964" width="280" height="58" rx="8" fill="var(--color-accent)" opacity="0.9"/>
                <text x="160" y="984" text-anchor="middle" font-family="var(--font-mono)" font-size="14" font-weight="700" fill="var(--color-bg)">Amygdala</text>
                <text x="160" y="1002" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-bg)" opacity="0.95">Emotional significance: threat? reward?</text>
                <text x="160" y="1017" text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--color-bg)" opacity="0.8">"does what I'm seeing matter to me?"</text>

                {/* ── Output 2: Hippocampus ── */}
                <rect x="380" y="964" width="280" height="58" rx="8" fill="var(--color-accent)" opacity="0.9"/>
                <text x="520" y="984" text-anchor="middle" font-family="var(--font-mono)" font-size="14" font-weight="700" fill="var(--color-bg)">Hippocampus</text>
                <text x="520" y="1002" text-anchor="middle" font-family="var(--font-sans)" font-size="11" fill="var(--color-bg)" opacity="0.95">Contextual memory: when, where, with whom</text>
                <text x="520" y="1017" text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--color-bg)" opacity="0.8">stores the full episode — not just the percept</text>

                {/* ── Feedback loop ── */}
                <path d="M 38 820 Q 18 820 18 600 Q 18 400 18 300 Q 18 230 38 220" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-dasharray="5,4" opacity="0.45"/>
                <polygon points="35,224 38,215 42,225" fill="var(--color-accent)" opacity="0.45"/>
                <text x="9" y="530" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-accent)" opacity="0.7" transform="rotate(-90, 9, 530)">Top-down feedback: more fibres downward than upward</text>

                {/* ── Bottom summary ── */}
                <rect x="80" y="1048" width="520" height="54" rx="8" fill="none" stroke="var(--color-border)" stroke-width="1.5"/>
                <text x="340" y="1070" text-anchor="middle" font-family="var(--font-sans)" font-size="12" font-weight="600" fill="var(--color-text-muted)">Full pipeline: ~100–150 ms from photon to contextualised memory</text>
                <text x="340" y="1090" text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--color-text-muted)">Like a CNN: edges (V1) → contours (V2) → shapes (V4) → objects (IT) → meaning (Ant. IT)</text>

                {/* ── Abstraction gradient bar ── */}
                <defs>
                  <linearGradient id="ventral-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" style="stop-color:var(--color-border);stop-opacity:0.6"/>
                    <stop offset="100%" style="stop-color:var(--color-accent);stop-opacity:0.8"/>
                  </linearGradient>
                </defs>
                <rect x="120" y="1118" width="440" height="10" rx="5" fill="url(#ventral-gradient)"/>
                <text x="120" y="1145" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-muted)">concrete</text>
                <text x="230" y="1145" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-muted)">edges</text>
                <text x="340" y="1145" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-muted)">shapes</text>
                <text x="450" y="1145" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-muted)">objects</text>
                <text x="560" y="1145" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-accent)">meaning</text>

                {/* Side accent bar */}
                <rect x="60" y="68" width="10" height="955" rx="0" fill="var(--color-accent)" opacity="0.08"/>
              </svg>
            </div>
          )}

          {section.bullets && section.bullets.length > 0 && (
            <ul class="day-bullets">
              {section.bullets.map(bullet => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}

          {section.mechanisms && section.mechanisms.length > 0 && (
            <ul class="day-bullets mechanism-list">
              {section.mechanisms.map((m, i) => (
                <li>
                  <strong>Mechanism {i + 1} — {m.name}</strong> <span class="region-tag">{m.region}</span><br />
                  {m.description}
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>

    <nav class="day-nav">
      {prevDay ? (
        <a href={`/notebooks/neuroscience/day-${prevDay.day}`} class="day-nav-link day-nav-prev">
          <span class="day-nav-direction">&larr; Day {prevDay.day}</span>
          <span class="day-nav-title">{prevDay.curiosityTitle}</span>
        </a>
      ) : <div />}
      {nextDay ? (
        <a href={`/notebooks/neuroscience/day-${nextDay.day}`} class="day-nav-link day-nav-next">
          <span class="day-nav-direction">Day {nextDay.day} &rarr;</span>
          <span class="day-nav-title">{nextDay.curiosityTitle}</span>
        </a>
      ) : <div />}
    </nav>
  </div>
</Layout>

<style>
  /* ── Day page header ── */
  .day-page-header {
    margin-bottom: 1.5rem;
  }

  .day-page-number {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .day-page-title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 0.25rem;
    line-height: 1.3;
  }

  /* ── Day navigation ── */
  .day-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .day-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    color: inherit;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: border-color 0.15s ease;
    max-width: 45%;
  }

  .day-nav-link:hover {
    border-color: var(--color-accent);
  }

  .day-nav-next {
    text-align: right;
    margin-left: auto;
  }

  .day-nav-direction {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .day-nav-title {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ── Side-by-side diagrams ── */
  .stream-diagrams {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .stream-diagram {
    flex: 1;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }

  .diagram-title {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .flow {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .flow-step {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding-left: 1rem;
    position: relative;
  }

  .flow-step::before {
    content: '↓';
    position: absolute;
    left: 1.45rem;
    top: -0.5rem;
    font-size: 0.6rem;
    color: var(--color-accent);
  }

  .flow-step:first-child::before {
    display: none;
  }

  .flow-node {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: 3px;
    padding: 0.15rem 0.45rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .flow-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .flow-step + .flow-step {
    margin-top: 0.4rem;
  }

  .flow-fork {
    flex-wrap: wrap;
    gap: 0.35rem 0.4rem;
  }

  .flow-fork .flow-label {
    flex-basis: 100%;
  }

  @media (max-width: 600px) {
    .stream-diagrams {
      flex-direction: column;
    }
  }

  /* ── Sections under diagrams ── */
  .day-section {
    margin-bottom: 1.25rem;
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.15rem;
  }

  .section-subtitle {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    line-height: 1.5;
    font-style: italic;
  }

  .day-section > .day-bullets {
    margin-bottom: 0.5rem;
  }

  .region-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: 3px;
    padding: 0.1rem 0.35rem;
    vertical-align: baseline;
  }

  .mechanism-list li {
    margin-bottom: 0.5rem;
  }

  /* ── Mini diagrams (Day 4+) ── */
  .mini-diagram {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.85rem 1rem;
    margin-bottom: 0.75rem;
    background: #f5efe8;
  }

  :global(html.dark) .mini-diagram {
    background: #2a2218;
  }

  /* Context modulation diagram */
  .ctx-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-bottom: 0.35rem;
  }

  .ctx-neuron {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 50%;
    width: 2.2rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ctx-center {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .ctx-neighbour {
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
  }

  .ctx-arrow {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .ctx-caption {
    text-align: center;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  .ctx-example {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ctx-example-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
  }

  .ctx-signal {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    min-width: 2.5rem;
    text-align: center;
  }

  .ctx-signal-noise { color: var(--color-text-muted); }
  .ctx-signal-active { color: var(--color-accent); }

  .ctx-result {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  /* Inhibitory surround diagram */
  .inhib-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 0.5rem;
  }

  .inhib-zone {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.3rem 0.6rem;
    text-align: center;
  }

  .inhib-end {
    background: var(--color-border);
    color: var(--color-text-muted);
    border-radius: 4px 0 0 4px;
  }

  .inhib-end:last-child {
    border-radius: 0 4px 4px 0;
  }

  .inhib-excite {
    background: var(--color-accent);
    color: var(--color-bg);
    padding: 0.3rem 1rem;
  }

  .inhib-examples {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .inhib-case {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
  }

  .inhib-line {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--color-accent);
  }

  .inhib-short { font-size: 0.7rem; }
  .inhib-long { font-size: 0.7rem; color: var(--color-text-muted); }

  /* ── Depth Neurons diagram (Day 5) ── */
  .dn-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dn-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .dn-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .dn-bar-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dn-depth-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    min-width: 1.8rem;
    text-align: center;
  }

  .dn-bar-track {
    flex: 1;
    height: 0.7rem;
    background: var(--color-border);
    border-radius: 3px;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .dn-bar {
    height: 100%;
    border-radius: 3px;
  }

  .dn-bar-excitatory {
    background: var(--color-accent);
  }

  .dn-bar-inhibitory-left,
  .dn-bar-inhibitory-right {
    background: var(--color-accent);
    opacity: 0.7;
  }

  .dn-bar-gap {
    background: transparent;
  }

  .dn-bar-near {
    background: var(--color-accent);
    opacity: 0.85;
    border-radius: 3px 0 0 3px;
  }

  .dn-bar-far {
    background: var(--color-text-muted);
    opacity: 0.5;
    border-radius: 0 3px 3px 0;
  }

  .dn-hint {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .dn-hint-row {
    display: flex;
    justify-content: space-between;
  }

  /* ── Amodal completion diagram (3-panel) ── */
  .amodal-panels {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .amodal-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .amodal-panel-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .amodal-label-brain {
    color: var(--color-accent);
  }

  .amodal-panel-scene {
    display: flex;
    align-items: center;
    gap: 0;
    height: 3rem;
  }

  .amodal-book-part {
    width: 1.8rem;
    height: 2.8rem;
    border: 2px solid var(--color-text-muted);
    border-radius: 2px;
  }

  .amodal-book-visible {
    background: var(--color-border);
    border-style: solid;
  }

  .amodal-book-hidden {
    background: transparent;
    border-style: dashed;
    opacity: 0.35;
  }

  .amodal-cup-block {
    width: 1.4rem;
    height: 2.2rem;
    background: var(--color-accent);
    border-radius: 3px 3px 6px 6px;
    margin: 0 -0.3rem;
    z-index: 1;
    position: relative;
  }

  .amodal-book-full {
    width: 4rem;
    height: 2.8rem;
    background: var(--color-border);
    border: 2px solid var(--color-text-muted);
    border-radius: 2px;
  }

  .amodal-cup-front {
    width: 1.4rem;
    height: 2.2rem;
    background: var(--color-accent);
    border-radius: 3px 3px 6px 6px;
    margin-left: -2.7rem;
    z-index: 1;
    position: relative;
  }

  .amodal-plus,
  .amodal-equals {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-muted);
    padding: 0 0.1rem;
  }

  .amodal-equals {
    color: var(--color-accent);
  }

  .amodal-panel-desc {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    color: var(--color-text-muted);
    text-align: center;
    max-width: 7rem;
    line-height: 1.3;
  }

  .amodal-desc-result {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── Kanizsa triangle (conic-gradient pac-mans) ── */
  .kanisza-container {
    position: relative;
    width: 10rem;
    height: 9rem;
    margin: 0 auto 0.35rem;
  }

  .kanisza-pac {
    position: absolute;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
  }

  .kanisza-pos-top {
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    background: conic-gradient(from 210deg, var(--color-accent) 0deg 300deg, transparent 300deg 360deg);
  }

  .kanisza-pos-bl {
    bottom: 0;
    left: 5%;
    background: conic-gradient(from 75deg, var(--color-accent) 0deg 300deg, transparent 300deg 360deg);
  }

  .kanisza-pos-br {
    bottom: 0;
    right: 5%;
    background: conic-gradient(from 345deg, var(--color-accent) 0deg 300deg, transparent 300deg 360deg);
  }

  /* ── Disparity capture diagram ── */
  .disp-surface {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    margin-bottom: 0.25rem;
  }

  .disp-region {
    width: 2.8rem;
    height: 2rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .disp-ambiguous {
    background: var(--color-border);
    color: var(--color-text-muted);
    border: 1px dashed var(--color-text-muted);
  }

  .disp-confident {
    background: var(--color-accent);
    color: var(--color-bg);
    font-size: 0.6rem;
    text-align: center;
    line-height: 1.2;
  }

  .disp-conf-label {
    font-family: var(--font-mono);
  }

  .disp-arrows {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .disp-arrow-center {
    font-size: 0.5rem;
  }

  /* ── Da Vinci stereopsis diagram (top-down SVG) ── */
  .dv-scene {
    display: flex;
    justify-content: center;
    margin-bottom: 0.4rem;
