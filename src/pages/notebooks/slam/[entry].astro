---
import Layout from '../../../layouts/Layout.astro';
import { experiment, entries } from '../../../data/slam-entries';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return entries.map(e => ({ params: { entry: `entry-${e.id}` }, props: { entryData: e } }));
};

const { entryData: entry } = Astro.props;

const title = `#${entry.id}: ${entry.title} — SLAM from Scratch — Arshad Kazi`;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

const currentIndex = entries.findIndex(e => e.id === entry.id);
const prevEntry = currentIndex > 0 ? entries[currentIndex - 1] : null;
const nextEntry = currentIndex < entries.length - 1 ? entries[currentIndex + 1] : null;
---

<Layout title={title} activeNav="/notebooks" description={`#${entry.id}: ${entry.title}`} ogImage="/images/og-tiny-experiments.jpg">
  <div class="experiment-page">
    <a href="/notebooks/slam" class="back-link">&larr; All Entries</a>

    <div class="day-page-header">
      <div class="entry-meta-row">
        <span class="entry-num">#{entry.id}</span>
        <span class="entry-date">{formatDate(entry.date)}</span>
        <div class="entry-meta-tags">
          {entry.tags.map(tag => (
            <span class="entry-meta-tag">{tag}</span>
          ))}
        </div>
      </div>
      <h1 class="day-page-title">{entry.title}</h1>
    </div>

    <div class="day-entry">
      {entry.bullets && entry.bullets.length > 0 && (
        <ul class="day-bullets">
          {entry.bullets.map(bullet => (
            <li set:html={bullet} />
          ))}
        </ul>
      )}

      {entry.diagram && (
        <div class="diagram-wrap" set:html={entry.diagram} />
      )}

      {entry.sections && entry.sections.map(section => (
        <div class="day-section">
          <h4 class="section-heading">{section.title}</h4>
          {section.subtitle && <p class="section-subtitle">{section.subtitle}</p>}

          {section.bullets.length > 0 && (
            <ul class="day-bullets">
              {section.bullets.map(bullet => (
                <li set:html={bullet} />
              ))}
            </ul>
          )}

          {section.diagram && (
            <div class="diagram-wrap" set:html={section.diagram} />
          )}
        </div>
      ))}
    </div>

    <nav class="day-nav">
      {prevEntry ? (
        <a href={`/notebooks/slam/entry-${prevEntry.id}`} class="day-nav-link prev">
          <span class="day-nav-arrow">&larr;</span>
          <span class="day-nav-label">#{prevEntry.id}</span>
        </a>
      ) : <span />}
      {nextEntry ? (
        <a href={`/notebooks/slam/entry-${nextEntry.id}`} class="day-nav-link next">
          <span class="day-nav-label">#{nextEntry.id}</span>
          <span class="day-nav-arrow">&rarr;</span>
        </a>
      ) : <span />}
    </nav>
  </div>
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    renderMathInElement(document.querySelector(".day-entry"), {
      delimiters: [
        { left: "$$", right: "$$", display: true },
        { left: "$", right: "$", display: false }
      ],
      throwOnError: false
    });
  });
</script>

<style>
  .entry-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: 0.3rem;
  }

  .entry-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .entry-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .entry-meta-tags {
    display: flex;
    gap: var(--space-xs);
  }

  .entry-meta-tag {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 500;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
  }

  .day-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .day-nav-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .day-nav-link:hover {
    color: var(--color-text);
  }

  .day-nav-arrow {
    font-size: 1rem;
  }

  .day-nav-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .diagram-wrap {
    margin: 1rem 0 0.5rem;
    overflow-x: auto;
  }
</style>
