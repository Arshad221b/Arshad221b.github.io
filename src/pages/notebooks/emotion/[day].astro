---
import Layout from '../../../layouts/Layout.astro';
import { experiment, days } from '../../../data/emotion-days';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return days
    .filter(d => d.bullets.length > 0)
    .map(d => ({ params: { day: `day-${d.day}` }, props: { dayData: d } }));
};

const { dayData: day } = Astro.props;

const title = `Day ${day.day}: ${day.curiosityTitle} — Understanding Emotion — Arshad Kazi`;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

const activeDays = days.filter(d => d.bullets.length > 0);
const currentIndex = activeDays.findIndex(d => d.day === day.day);
const prevDay = currentIndex > 0 ? activeDays[currentIndex - 1] : null;
const nextDay = currentIndex < activeDays.length - 1 ? activeDays[currentIndex + 1] : null;
---

<Layout title={title} activeNav="/notebooks" description={`Day ${day.day}: ${day.curiosityTitle}`} ogImage="/images/og-thoughts.jpg">
  <div class="experiment-page">
    <a href="/notebooks/emotion" class="back-link">&larr; All Days</a>

    <div class="day-page-header">
      <span class="day-page-number">Day {day.day} &mdash; {formatDate(day.date)}</span>
      <h1 class="day-page-title">{day.curiosityTitle}</h1>
    </div>

    <div class="day-entry">
      {day.summary && (
        <p class="day-summary">{day.summary}</p>
      )}

      {day.bullets && day.bullets.length > 0 && (
        <ul class="day-bullets top-bullets">
          {day.bullets.map(bullet => (
            <li set:html={bullet} />
          ))}
        </ul>
      )}

      {day.sections && day.sections.map(section => (
        <div class="day-section">
          <h4 class="section-heading">{section.title}</h4>
          {section.subtitle && <p class="section-subtitle">{section.subtitle}</p>}

          {section.showTripartiteDiagram && (
            <div class="mini-diagram tripartite-diagram">
              <svg class="tripartite-svg" viewBox="0 0 420 380" xmlns="http://www.w3.org/2000/svg">
                {/* Title */}
                <text x="210" y="24" text-anchor="middle" font-family="var(--font-serif)" font-size="14" font-weight="700" fill="var(--color-accent)">Plato's Tripartite Soul</text>

                {/* Logos — Head (top) */}
                <rect x="110" y="44" width="200" height="68" rx="8" fill="var(--color-accent-soft)" stroke="var(--color-accent)" stroke-width="1.5"/>
                <text x="210" y="68" text-anchor="middle" font-family="var(--font-mono)" font-size="13" font-weight="700" fill="var(--color-accent)">Logos (Reason)</text>
                <text x="210" y="84" text-anchor="middle" font-family="var(--font-sans)" font-size="9.5" fill="var(--color-text-muted)">Head — eternal truths, logic</text>
                <text x="210" y="100" text-anchor="middle" font-family="var(--font-mono)" font-size="8.5" fill="var(--color-accent)" opacity="0.7">virtue: Wisdom</text>

                {/* Label: GOVERNS */}
                <line x1="210" y1="112" x2="210" y2="138" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="205,135 210,144 215,135" fill="var(--color-accent)"/>
                <text x="232" y="130" font-family="var(--font-mono)" font-size="7.5" fill="var(--color-text-muted)">governs</text>

                {/* Thumos — Chest (middle) */}
                <rect x="110" y="148" width="200" height="68" rx="8" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-dasharray="5,3"/>
                <text x="210" y="172" text-anchor="middle" font-family="var(--font-mono)" font-size="13" font-weight="700" fill="var(--color-accent)">Thumos (Spirit)</text>
                <text x="210" y="188" text-anchor="middle" font-family="var(--font-sans)" font-size="9.5" fill="var(--color-text-muted)">Chest — ambition, pride, honour</text>
                <text x="210" y="204" text-anchor="middle" font-family="var(--font-mono)" font-size="8.5" fill="var(--color-accent)" opacity="0.7">virtue: Courage</text>

                {/* Arrow: Thumos enforces on Epithumia */}
                <line x1="210" y1="216" x2="210" y2="242" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="205,239 210,248 215,239" fill="var(--color-accent)"/>
                <text x="238" y="234" font-family="var(--font-mono)" font-size="7.5" fill="var(--color-text-muted)">enforces</text>

                {/* Epithumia — Belly (bottom) */}
                <rect x="110" y="252" width="200" height="68" rx="8" fill="none" stroke="var(--color-border)" stroke-width="1.5"/>
                <text x="210" y="276" text-anchor="middle" font-family="var(--font-mono)" font-size="13" font-weight="700" fill="var(--color-text-muted)">Epithumia (Appetite)</text>
                <text x="210" y="292" text-anchor="middle" font-family="var(--font-sans)" font-size="9.5" fill="var(--color-text-muted)">Belly — hunger, craving, greed</text>
                <text x="210" y="308" text-anchor="middle" font-family="var(--font-mono)" font-size="8.5" fill="var(--color-accent)" opacity="0.7">virtue: Temperance</text>

                {/* Curved feedback arrow: Thumos fights for Logos */}
                <path d="M 108 182 Q 60 182 60 106 Q 60 78 108 78" fill="none" stroke="var(--color-accent)" stroke-width="1.2" stroke-dasharray="4,3" opacity="0.5"/>
                <polygon points="105,73 113,78 105,83" fill="var(--color-accent)" opacity="0.5"/>
                <text x="30" y="135" font-family="var(--font-mono)" font-size="7" fill="var(--color-text-muted)" text-anchor="middle" transform="rotate(-90, 30, 135)">fights for reason</text>

                {/* Annotation */}
                <text x="210" y="348" text-anchor="middle" font-family="var(--font-sans)" font-size="9" fill="var(--color-text-muted)" font-style="italic">well-ordered soul: reason leads, spirit enforces, appetite obeys</text>
              </svg>
            </div>
          )}

          {section.showEkmanDiagram && (
            <div class="mini-diagram ekman-diagram">
              <svg class="ekman-svg" viewBox="0 0 480 300" xmlns="http://www.w3.org/2000/svg">
                {/* Title */}
                <text x="240" y="22" text-anchor="middle" font-family="var(--font-serif)" font-size="14" font-weight="700" fill="var(--color-accent)">Ekman's Cross-Cultural Experiment (1960s)</text>

                {/* Left side: Photos shown */}
                <rect x="30" y="44" width="120" height="100" rx="6" fill="var(--color-accent-soft)" stroke="var(--color-accent)" stroke-width="1"/>
                <text x="90" y="62" text-anchor="middle" font-family="var(--font-mono)" font-size="9" font-weight="700" fill="var(--color-accent)">Photos Shown</text>
                <text x="90" y="80" text-anchor="middle" font-family="var(--font-sans)" font-size="20">😊 😢 😨</text>
                <text x="90" y="102" text-anchor="middle" font-family="var(--font-sans)" font-size="20">😠 🤢 😲</text>
                <text x="90" y="132" text-anchor="middle" font-family="var(--font-mono)" font-size="7.5" fill="var(--color-text-muted)">6 basic expressions</text>

                {/* Arrow */}
                <line x1="155" y1="94" x2="185" y2="94" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="182,89 192,94 182,99" fill="var(--color-accent)"/>
                <text x="174" y="84" font-family="var(--font-mono)" font-size="7" fill="var(--color-text-muted)">shown to</text>

                {/* Middle: Isolated tribe */}
                <rect x="195" y="44" width="130" height="100" rx="6" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-dasharray="5,3"/>
                <text x="260" y="64" text-anchor="middle" font-family="var(--font-mono)" font-size="9" font-weight="700" fill="var(--color-accent)">Papua New Guinea</text>
                <text x="260" y="82" text-anchor="middle" font-family="var(--font-sans)" font-size="9" fill="var(--color-text-muted)">Remote tribe with</text>
                <text x="260" y="94" text-anchor="middle" font-family="var(--font-sans)" font-size="9" fill="var(--color-text-muted)">zero Western contact</text>
                <text x="260" y="106" text-anchor="middle" font-family="var(--font-sans)" font-size="9" fill="var(--color-text-muted)">no TV, no movies</text>
                <text x="260" y="132" text-anchor="middle" font-family="var(--font-mono)" font-size="7.5" fill="var(--color-text-muted)">no cultural influence</text>

                {/* Arrow */}
                <line x1="330" y1="94" x2="355" y2="94" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="352,89 362,94 352,99" fill="var(--color-accent)"/>

                {/* Right: Result */}
                <rect x="365" y="44" width="90" height="100" rx="6" fill="var(--color-accent-soft)" stroke="var(--color-accent)" stroke-width="1.5"/>
                <text x="410" y="64" text-anchor="middle" font-family="var(--font-mono)" font-size="9" font-weight="700" fill="var(--color-accent)">Result</text>
                <text x="410" y="88" text-anchor="middle" font-family="var(--font-serif)" font-size="28" font-weight="700" fill="var(--color-accent)">100%</text>
                <text x="410" y="106" text-anchor="middle" font-family="var(--font-sans)" font-size="9" fill="var(--color-text-muted)">matched</text>
                <text x="410" y="118" text-anchor="middle" font-family="var(--font-sans)" font-size="9" fill="var(--color-text-muted)">correctly</text>

                {/* Bottom section: Display Rules experiment */}
                <line x1="40" y1="168" x2="440" y2="168" stroke="var(--color-border)" stroke-width="1"/>
                <text x="240" y="188" text-anchor="middle" font-family="var(--font-serif)" font-size="11" font-weight="700" fill="var(--color-accent)">But: Cultural Display Rules</text>

                {/* Watching together */}
                <rect x="40" y="200" width="180" height="80" rx="6" fill="none" stroke="var(--color-border)" stroke-width="1"/>
                <text x="130" y="218" text-anchor="middle" font-family="var(--font-mono)" font-size="8.5" font-weight="700" fill="var(--color-text-muted)">Watching film WITH others</text>
                {/* Japanese bar - low */}
                <rect x="65" y="258" width="45" height="14" rx="3" fill="var(--color-border)"/>
                <text x="88" y="268" text-anchor="middle" font-family="var(--font-mono)" font-size="7" fill="var(--color-text-muted)">JP: low</text>
                {/* American bar - high */}
                <rect x="125" y="238" width="45" height="34" rx="3" fill="var(--color-accent)"/>
                <text x="148" y="258" text-anchor="middle" font-family="var(--font-mono)" font-size="7" fill="var(--color-bg)">US: high</text>
                <text x="130" y="244" text-anchor="middle" font-family="var(--font-sans)" font-size="7.5" fill="var(--color-text-muted)">facial expression</text>

                {/* Watching alone */}
                <rect x="260" y="200" width="180" height="80" rx="6" fill="var(--color-accent-soft)" stroke="var(--color-accent)" stroke-width="1"/>
                <text x="350" y="218" text-anchor="middle" font-family="var(--font-mono)" font-size="8.5" font-weight="700" fill="var(--color-accent)">Watching film ALONE</text>
                {/* Japanese bar - equal */}
                <rect x="285" y="242" width="45" height="30" rx="3" fill="var(--color-accent)"/>
                <text x="308" y="260" text-anchor="middle" font-family="var(--font-mono)" font-size="7" fill="var(--color-bg)">JP</text>
                {/* American bar - equal */}
                <rect x="345" y="242" width="45" height="30" rx="3" fill="var(--color-accent)"/>
                <text x="368" y="260" text-anchor="middle" font-family="var(--font-mono)" font-size="7" fill="var(--color-bg)">US</text>
                <text x="350" y="240" text-anchor="middle" font-family="var(--font-sans)" font-size="7.5" fill="var(--color-text-muted)">identical expression</text>
              </svg>
              <div class="ekman-insight">
                <span class="ekman-label">Key insight:</span> the emotion is universal and biological, the display rules are cultural. You feel the same thing — you just learn when to show it.
              </div>
            </div>
          )}

          {section.bullets.length > 0 && (
            <ul class="day-bullets section-bullets">
              {section.bullets.map(bullet => (
                <li set:html={bullet} />
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>

    <nav class="day-nav">
      {prevDay ? (
        <a href={`/notebooks/emotion/day-${prevDay.day}`} class="day-nav-link prev">
          <span class="day-nav-arrow">&larr;</span>
          <span class="day-nav-label">Day {prevDay.day}</span>
        </a>
      ) : <span />}
      {nextDay ? (
        <a href={`/notebooks/emotion/day-${nextDay.day}`} class="day-nav-link next">
          <span class="day-nav-label">Day {nextDay.day}</span>
          <span class="day-nav-arrow">&rarr;</span>
        </a>
      ) : <span />}
    </nav>
  </div>
</Layout>

<style>
  .day-page-header {
    margin-bottom: 1.5rem;
  }

  .day-page-number {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .day-page-title {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 0.25rem;
    line-height: 1.3;
  }

  .day-summary {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    padding: 0.8rem 1rem;
    border-left: 3px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: 0 6px 6px 0;
  }

  .top-bullets {
    margin-bottom: 2rem;
  }

  .day-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .day-section:first-of-type {
    border-top: 2px solid var(--color-accent);
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--color-accent);
    margin-bottom: 0.3rem;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .section-bullets li {
    font-size: 1rem;
    margin-bottom: 0.6rem;
  }

  .day-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .day-nav-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .day-nav-link:hover {
    color: var(--color-text);
  }

  .day-nav-arrow {
    font-size: 1rem;
  }

  .day-nav-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  /* Diagram styles */
  .mini-diagram {
    margin: 1.2rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tripartite-svg,
  .ekman-svg {
    width: 100%;
    max-width: 480px;
    height: auto;
  }

  .ekman-insight {
    margin-top: 0.6rem;
    padding: 0.5rem 0.8rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border-left: 2px solid var(--color-accent);
    max-width: 480px;
  }

  .ekman-label {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.75rem;
    color: var(--color-accent);
  }
</style>
