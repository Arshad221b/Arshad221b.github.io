---
interface Props {
  title: string;
  date: string;
  heroImage?: string;
}

const { title, date, heroImage } = Astro.props;

import Layout from './Layout.astro';

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={`${title} — Arshad Kazi`} activeNav="/thoughts">
  <article class="blog-post">
    {heroImage && (
      <div class="hero-image">
        <img src={heroImage} alt={title} />
      </div>
    )}
    <header class="blog-post-header">
      <div class="blog-post-meta">
        <time>{formatDate(date)}</time>
      </div>
      <h1>{title}</h1>
    </header>

    <div class="blog-post-content">
      <slot />
    </div>

    <section class="giscus-wrapper">
      <h2 class="giscus-heading">Comments & Reactions</h2>
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo="Arshad221b/Arshad221b.github.io"
        data-repo-id="R_kgDORWD4-g"
        data-category="General"
        data-category-id="DIC_kwDORWD4-s4C3CtQ"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="en"
        data-loading="lazy"
        crossorigin="anonymous"
        async>
      </script>
    </section>

    <footer class="blog-post-footer">
      <a href="/thoughts" class="back-link">&larr; Back to all thoughts</a>
    </footer>
  </article>
</Layout>
